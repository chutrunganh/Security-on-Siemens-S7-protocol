# Suricata rules for Siemens S7comm traffic used in this thesis lab.
# Network model: CONTROL_NET = PLC segment, SUPERVISOR_NET = authorized HMI/engineering,
# EXTERNAL_NET = attacker segment (see suricata.yaml / patch_suricata_yaml.py).
#
# Source policy (live lab): recon / write / start-stop / MITM rules use
#   !$SUPERVISOR_NET any -> $CONTROL_NET 102
# so legitimate S7comm from SUPERVISOR_NET is not flagged.
#
# Exception — block upload/download (SID 1000020–1000026): any -> any :102
# for offline PCAP replay (reference captures may use IPs outside HOME_NET).
#
# S7comm over TCP payload layout used by most rules:
#   0      : TPKT version 0x03
#   1      : TPKT reserved 0x00
#   4..6   : COTP data TPDU 0x02 f0 80
#   7      : S7 protocol id 0x32
#   8      : ROSCTR, 0x01 Job, 0x03 Ack_Data, 0x07 Userdata
#   17     : first S7 parameter byte for Job/Userdata packets with normal COTP DT

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Setup Communication to PLC"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|F0|"; offset:17; depth:1; sid:1000001; rev:2; metadata:service iso-tsap, protocol s7comm, attack reconnaissance; priority:3;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Read SZL request - PLC information enumeration"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 07|"; offset:4; depth:5; content:"|00 01 12 04 11 44 01 00|"; offset:17; depth:8; sid:1000002; rev:2; metadata:service iso-tsap, protocol s7comm, attack reconnaissance; priority:2;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Read SZL module identification 0x0011"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 07|"; offset:4; depth:5; content:"|00 01 12 04 11 44 01 00|"; offset:17; depth:8; content:"|00 11 00 01|"; distance:0; within:12; sid:1000003; rev:2; metadata:service iso-tsap, protocol s7comm, attack reconnaissance; priority:2;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Read SZL communication status 0x001c"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 07|"; offset:4; depth:5; content:"|00 01 12 04 11 44 01 00|"; offset:17; depth:8; content:"|00 1C 00 00|"; distance:0; within:12; sid:1000004; rev:2; metadata:service iso-tsap, protocol s7comm, attack reconnaissance; priority:2;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM List Blocks request - PLC block inventory enumeration"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 07|"; offset:4; depth:5; content:"|00 01 12 04 11 13 01 00|"; offset:17; depth:8; sid:1000005; rev:2; metadata:service iso-tsap, protocol s7comm, attack reconnaissance; priority:2;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Write Var request to PLC"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|05|"; offset:17; depth:1; sid:1000010; rev:2; metadata:service iso-tsap, protocol s7comm, attack modify_process_variable; priority:1;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM Write Var to DB memory area"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|05|"; offset:17; depth:1; content:"|12|"; offset:19; depth:1; content:"|10|"; offset:21; depth:1; content:"|84|"; distance:5; within:1; sid:1000011; rev:3; metadata:service iso-tsap, protocol s7comm, attack modify_process_variable; priority:1;)

alert tcp $CONTROL_NET 102 -> $SUPERVISOR_NET any (msg:"ICS S7COMM suspicious Ack_Data response to HMI/engineering station"; flow:from_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 03|"; offset:4; depth:5; sid:1000013; rev:2; metadata:service iso-tsap, protocol s7comm, attack possible_mitm_observation; threshold:type both, track by_src, count 60, seconds 10; priority:3;)

# --- Block upload/download: any/any for offline PCAP replay (SID 1000020–1000026) ---

alert tcp any any -> any 102 (msg:"ICS S7COMM Request Download block to PLC"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1A|"; offset:17; depth:1; sid:1000020; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_download; priority:1;)

alert tcp any 102 -> any any (msg:"ICS S7COMM PLC requests Download Block data"; flow:from_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1B|"; offset:17; depth:1; sid:1000021; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_download; priority:1;)

alert tcp any any -> any 102 (msg:"ICS S7COMM Download Ended"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1C|"; offset:17; depth:1; sid:1000022; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_download; priority:1;)

alert tcp any any -> any 102 (msg:"ICS S7COMM Start Upload block from PLC"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1D|"; offset:17; depth:1; sid:1000023; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_upload; priority:1;)

alert tcp any any -> any 102 (msg:"ICS S7COMM Upload Block request"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1E|"; offset:17; depth:1; sid:1000024; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_upload; priority:1;)

alert tcp any any -> any 102 (msg:"ICS S7COMM End Upload"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|1F|"; offset:17; depth:1; sid:1000025; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_upload; priority:1;)

alert tcp any any -> any 102 (msg:"ICS S7COMM client sends Download Block data to PLC"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 03|"; offset:4; depth:5; content:"|1B|"; offset:19; depth:1; sid:1000026; rev:3; metadata:service iso-tsap, protocol s7comm, attack program_download; priority:1;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM PLC Control command"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|28|"; offset:17; depth:1; sid:1000030; rev:2; metadata:service iso-tsap, protocol s7comm, attack plc_control; priority:1;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM replayed Start CPU P_PROGRAM"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|28|"; offset:17; depth:1; content:"P_PROGRAM"; distance:0; within:24; sid:1000031; rev:2; metadata:service iso-tsap, protocol s7comm, attack start_stop_replay; priority:1;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM PLC Stop command"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|29|"; offset:17; depth:1; sid:1000032; rev:2; metadata:service iso-tsap, protocol s7comm, attack plc_stop; priority:1;)

alert tcp !$SUPERVISOR_NET any -> $CONTROL_NET 102 (msg:"ICS S7COMM replayed Stop CPU P_PROGRAM"; flow:to_server,established; content:"|03 00|"; offset:0; depth:2; content:"|02 F0 80 32 01|"; offset:4; depth:5; content:"|29|"; offset:17; depth:1; content:"P_PROGRAM"; distance:0; within:24; sid:1000033; rev:2; metadata:service iso-tsap, protocol s7comm, attack start_stop_replay; priority:1;)
